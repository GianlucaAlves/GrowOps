// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String?
  passwordHash String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  sessions     Session[]
  gardens      Garden[]
  plants       Plant[]
  tasks        Task[]
  events       Event[]
  photos       Photo[]
  metadata     PlantMetadata[]
}

model Garden {
  id          String   @id @default(cuid())
  userId      String
  name        String
  type        String?
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  plants Plant[]

  @@index([userId])
}

model Session {
  id               String    @id @default(cuid())
  userId           String
  refreshTokenHash String
  expiresAt        DateTime
  createdAt        DateTime  @default(now())
  revokedAt        DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Plant {
  id        String   @id @default(cuid())
  userId    String
  gardenId  String?
  name      String
  species   String?
  location  String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  garden   Garden?   @relation(fields: [gardenId], references: [id], onDelete: SetNull)
  tasks    Task[]
  events   Event[]
  metadata PlantMetadata?

  @@index([userId])
  @@index([gardenId])
}

model Task {
  id        String   @id @default(cuid())
  userId    String
  plantId   String?
  title     String
  type      TaskType
  dueAt     DateTime
  completed Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  plant Plant? @relation(fields: [plantId], references: [id], onDelete: SetNull)
  photos Photo[]

  @@index([userId, dueAt])
  @@index([plantId])
}

model Event {
  id          String    @id @default(cuid())
  userId      String
  plantId     String
  type        EventType
  description String?
  note        String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  plant Plant @relation(fields: [plantId], references: [id], onDelete: Cascade)
  photos Photo[]

  @@index([userId, createdAt])
  @@index([plantId, createdAt])
}

model Photo {
  id        String   @id @default(cuid())
  userId    String
  eventId   String?
  taskId    String?

  // Store object storage keys (recommended). Your API can build signed/public URLs.
  key       String
  thumbKey  String

  mimeType  String
  width     Int?
  height    Int?
  createdAt DateTime @default(now())

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  event Event? @relation(fields: [eventId], references: [id], onDelete: SetNull)
  task  Task?  @relation(fields: [taskId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([eventId])
  @@index([taskId])
}

model PlantMetadata {
  id                   String   @id @default(cuid())
  userId               String
  plantId              String   @unique
  wateringIntervalDays Int?
  feedingIntervalDays  Int?
  notes                String?

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  plant Plant @relation(fields: [plantId], references: [id], onDelete: Cascade)

  @@index([userId])
}

enum TaskType {
  watering
  feeding
  note
  photo
}

enum EventType {
  watering
  feeding
  pruning
  training
  ipm
  transplant
  observation
  phase_change
  note
  photo
}